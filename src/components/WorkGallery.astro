---
const videoPath = "/assets/WEB/HOME/";
const works = [
  {
    title: "MÉTODO JOTADE",
    subtitle: "Mira como trabajo",
    desc: "Un objetivo claro. Un diseño lógico. Una intención real. Así entiendo cada proceso de entrenamiento. Porque entrenar no es hacer más, sino hacer lo que realmente te acerca a rendir mejor.",
    video: videoPath + "Vídeo 5. Método Jotade (Desde el segundo 4).mp4"
  },
  {
    title: "JD ATHLETES",
    subtitle: "Potencia elástica",
    desc: "Alto rendimiento no es hacer más. Es hacer lo que toca. Preparación individual para deportistas que quieren entrenar con estructura, intención y una lógica real de rendimiento.",
    video: videoPath + "Vídeo 6. JD Athletes.mp4"
  },
  {
    title: "JD PERFORMERS",
    subtitle: "Prevención y fuerza",
    desc: "No es solo salud. Es rendimiento en tu realidad. Entrenamiento individual para personas que quieren recuperarse, moverse mejor y construir una base física sólida con sentido.",
    video: videoPath + "Vídeo 7. JD Performers.mp4"
  }
];
---

<section class="work-section">
  <div class="work-container">
    {works.map((item, index) => (
      <div class={`work-block ${index % 2 !== 0 ? 'reverse' : ''}`}>
        <div class="work-video-container">
          <video 
            src={item.video} 
            autoplay 
            muted 
            loop 
            playsinline 
            class="work-video"
          ></video>
          <div class="video-overlay"></div>
        </div>
        
        <div class="work-content-container">
          <div class="work-text-box">
            <span class="work-subtitle">{item.subtitle}</span>
            <h2 class="work-title">{item.title}</h2>
            <p class="work-desc">{item.desc}</p>
            <div class="work-line"></div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .work-section {
    background-color: var(--color-dark);
    color: var(--color-light);
    width: 100%;
    overflow: hidden;
  }

  .work-container {
    display: flex;
    flex-direction: column;
  }

  .work-block {
    position: relative;
    display: flex;
    min-height: 100vh;
    width: 100%;
    align-items: center;
  }

  /* Video half */
  .work-video-container {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 60%;
    height: 80vh;
    right: 5%;
    z-index: 1;
    border-radius: 4px;
    overflow: hidden;
  }

  .reverse .work-video-container {
    right: auto;
    left: 5%;
  }

  .work-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.8) contrast(1.1);
  }

  .video-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, var(--color-dark) 0%, transparent 20%, transparent 80%, var(--color-dark) 100%);
  }

  /* Content half */
  .work-content-container {
    position: relative;
    width: 50%;
    padding: 10% 5%;
    z-index: 2;
    pointer-events: none;
  }

  .reverse .work-content-container {
    margin-left: 50%;
  }

  .work-text-box {
    background: rgba(26, 26, 26, 0.85); /* Slightly transparent to see video behind */
    backdrop-filter: blur(10px);
    padding: 4rem;
    pointer-events: auto;
    border-left: 2px solid var(--color-primary);
    transform: translateX(0);
  }

  .reverse .work-text-box {
    border-left: none;
    border-right: 2px solid var(--color-primary);
    text-align: right;
  }

  .work-subtitle {
    display: block;
    font-family: 'Montserrat', sans-serif;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .work-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 2rem;
    line-height: 1;
  }

  .work-desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 2rem;
  }

  .work-line {
    width: 60px;
    height: 4px;
    background-color: var(--color-primary);
  }

  .reverse .work-line {
    margin-left: auto;
  }

  @media (max-width: 1024px) {
    .work-block {
      flex-direction: column;
      justify-content: flex-start;
      padding: 2.5rem 0;
      height: auto;
      min-height: auto;
    }

    .work-video-container {
      position: relative;
      top: 0;
      transform: none;
      width: 100%;
      height: 45vh;
      right: 0;
      left: 0;
      margin-bottom: -3rem; /* Overlap effect */
    }

    .work-content-container {
      width: 92%;
      padding: 0;
      margin: 0 auto !important;
    }

    .work-text-box {
      padding: 2rem 1.5rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('DOMContentLoaded', () => {
    const blocks = document.querySelectorAll('.work-block');

    blocks.forEach((block) => {
      const video = block.querySelector('.work-video-container');
      const text = block.querySelector('.work-text-box');

      // Video Entrance Parallax
      gsap.fromTo(video, 
        { y: 100, opacity: 0, scale: 0.95 },
        { 
          y: 0, 
          opacity: 1, 
          scale: 1,
          scrollTrigger: {
            trigger: block,
            start: "top 80%",
            end: "top 20%",
            scrub: 1
          }
        }
      );

      // Text Overlap Slide
      gsap.fromTo(text, 
        { x: block.classList.contains('reverse') ? 100 : -100, opacity: 0 },
        { 
          x: 0, 
          opacity: 1, 
          scrollTrigger: {
            trigger: block,
            start: "top 60%",
            end: "top 30%",
            scrub: 1
          }
        }
      );
    });
  });
</script>
