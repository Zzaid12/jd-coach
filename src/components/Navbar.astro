---
---

<nav class="navbar">
  <div class="navbar-container">
    <a href="/" class="navbar-logo">
      <img src="/logo.png" alt="JD Coach" />
    </a>
    <button class="nav-toggler" aria-label="Menu">
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="nav-content">
    <div class="nav-bg"></div>
    <div class="nav-bg"></div>
    <div class="nav-bg"></div>
    <div class="nav-bg"></div>
    
    <div class="nav-items">
      <div class="nav-items-col">
        <div class="nav-socials">
          <a href="https://instagram.com/jotadecoach" target="_blank">Instagram</a>
          <a href="#">Youtube</a>
          <a href="#">TikTok</a>
        </div>
        <div class="nav-legal">
          <a href="#">Aviso Legal</a>
          <a href="#">Privacidad</a>
        </div>
      </div>
      <div class="nav-items-col">
        <div class="nav-primary-links">
          <a href="/">Home</a>
          <a href="/athletes">JD Athletes</a>
          <a href="/performers">JD Performers</a>
        </div>
        <div class="nav-secondary-links">
          <a href="#contacto">Contacto</a>
          <a href="#quien-soy">Sobre mí</a>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(SplitText);

  window.addEventListener('DOMContentLoaded', () => {
    const navbar = document.querySelector('.navbar');
    const navToggler = document.querySelector(".nav-toggler");
    const navBgs = document.querySelectorAll(".nav-bg");
    const navItems = document.querySelector(".nav-items");

    // Pre-animation for navbar entrance
    gsap.set(navbar, { yPercent: -100, opacity: 0 });
    gsap.to(navbar, {
      yPercent: 0,
      opacity: 1,
      duration: 0.8,
      delay: sessionStorage.getItem('jd-visited') ? 0.3 : 6.5,
      ease: "power2.out"
    });

    let isMenuOpen = false;
    let isAnimating = false;

    // Split text logic
    const splitLinks = new SplitText(".nav-items a", {
      type: "lines",
      linesClass: "line-wrapper"
    });

    // To prevent clipping, we ensure the wrappers have overflow hidden and enough padding
    // We target the lines themselves which are now inside .line-wrapper
    const lines = splitLinks.lines;
    
    // Initial state: hidden
    gsap.set(lines, { yPercent: 110 });

    // Main Menu Timeline
    const tl = gsap.timeline({
      paused: true,
      onStart: () => { isAnimating = true; },
      onComplete: () => { isAnimating = false; },
      onReverseComplete: () => {
        isAnimating = false;
        gsap.set(".nav-content", { pointerEvents: "none" });
      },
    });

    // Reveal Logic
    tl.to(".nav-content", { pointerEvents: "auto", duration: 0 }, 0);
    
    tl.to(navBgs, {
      scaleY: 1,
      duration: 0.7,
      stagger: 0.08,
      ease: "power3.inOut"
    });

    tl.to(".nav-items", {
      clipPath: "polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%)",
      duration: 0.7,
      ease: "power3.inOut"
    }, "-=0.5");

    tl.to(lines, {
      yPercent: 0,
      duration: 0.8,
      stagger: 0.03,
      ease: "power4.out"
    }, "-=0.2");

    if (navToggler) {
      navToggler.addEventListener("click", () => {
        if (isAnimating) return;
        navToggler.classList.toggle("open");
        if (!isMenuOpen) {
          tl.play();
        } else {
          tl.reverse();
        }
        isMenuOpen = !isMenuOpen;
      });
    }

    // Close on click
    document.querySelectorAll(".nav-items a").forEach(link => {
      link.addEventListener("click", () => {
        if (isMenuOpen && !isAnimating) {
          navToggler?.classList.remove("open");
          tl.reverse();
          isMenuOpen = false;
        }
      });
    });
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1100;
    background: rgba(26, 26, 26, 0.9);
    backdrop-filter: blur(15px);
    border-bottom: 1px solid #333333;
  }

  .navbar-container {
    width: 100%;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 100;
  }

  .navbar-logo img {
    height: 40px;
    filter: brightness(0) invert(1);
  }

  .nav-toggler {
    background: none;
    border: none;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    cursor: pointer;
    padding: 10px;
  }

  .nav-toggler span {
    width: 35px;
    height: 2px;
    background-color: #fff;
    transition: all 0.4s cubic-bezier(0.7, 0, 0.3, 1);
  }

  .nav-toggler.open span:first-child { transform: translateY(5px) rotate(45deg); }
  .nav-toggler.open span:last-child { transform: translateY(-5px) rotate(-45deg); width: 35px; }

  .nav-content {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    pointer-events: none;
    z-index: 1050;
  }

  .nav-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transform: scaleY(0);
    transform-origin: top;
    will-change: transform;
  }

  /* Distinctive orange shades */
  .nav-bg:nth-child(1) { background-color: var(--color-primary); z-index: 1; }
  .nav-bg:nth-child(2) { background-color: #1a1a1a; z-index: 2; }
  .nav-bg:nth-child(3) { background-color: #222; z-index: 3; }
  .nav-bg:nth-child(4) { background-color: #000; z-index: 4; }

  .nav-items {
    position: relative;
    display: flex;
    width: 100%;
    height: 100%;
    gap: 4rem;
    padding: 12rem 4rem 4rem;
    background-color: #000;
    z-index: 10;
    clip-path: polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%);
    will-change: clip-path;
  }

  .nav-items-col:nth-child(1) { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
  .nav-items-col:nth-child(2) { flex: 3; display: flex; flex-direction: column; gap: 4rem; }

  .nav-items a {
    text-decoration: none;
    color: #fff;
    display: block;
    line-height: 1.2;
    font-family: 'Montserrat', sans-serif;
  }

  .nav-items a:hover { color: var(--color-primary); }

  .nav-socials a { font-size: 1.2rem; text-transform: uppercase; margin-bottom: 0.5rem; }
  .nav-legal a { font-size: 0.8rem; opacity: 0.4; }

  .nav-primary-links a {
    font-size: clamp(3rem, 7.5vw, 6rem);
    font-family: 'Anton', sans-serif;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .nav-secondary-links { display: flex; gap: 3rem; }
  .nav-secondary-links a { font-size: 1.5rem; text-transform: uppercase; }

  /* Critical fix for SplitText clipping */
  :global(.line-wrapper) {
    overflow: hidden !important;
    padding-bottom: 0.5rem;
    margin-bottom: -0.5rem;
  }

  @media (max-width: 1024px) {
    .nav-items { flex-direction: column-reverse; padding: 8rem 2rem 2rem; gap: 2rem; }
    .nav-primary-links a { font-size: 3rem; }
    .nav-secondary-links { flex-direction: column; gap: 1rem; }
  }
</style>
