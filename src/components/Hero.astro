---
interface Props {
  title?: string;
  titleLine2?: string;
  videoSrc?: string;
  showCta?: boolean;
}

const { 
  title = "Tu rendimiento es mi prioridad", 
  titleLine2 = "Lo mejor empieza aquí",
  videoSrc = "/videos%20hero/VID_20260326_052121_785_bsl.mp4",
  showCta = true
} = Astro.props;
---

<section class="hero">
  <div class="hero-video-container">
    <video 
      class="hero-bg-video" 
      autoplay 
      loop 
      muted 
      playsinline 
      poster={videoSrc}
    >
      <source src={videoSrc} type="video/mp4" />
      Tu navegador no soporta el video.
    </video>
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <div class="hero-logo-container">
      <img src="/logo.png" alt="JD Coach Logo" class="hero-logo" />
    </div>
    
    <h1 class="hero-title">
      <span class="line">{title}</span>
      {titleLine2 && <span class="line">{titleLine2}</span>}
    </h1>
    
    {showCta && (
      <div class="hero-cta">
        <a href="#contacto" class="btn-primary">Contacta conmigo</a>
        <a href="#quien-soy" class="btn-secondary">Conóceme más</a>
      </div>
    )}
  </div>
  
  <div class="hero-scroll-indicator">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  function initHero() {
    const heroLogo = document.querySelector('.hero-logo-container');
    const heroLines = document.querySelectorAll('.hero-title .line');
    const heroCta = document.querySelector('.hero-cta');
    const scrollIndicator = document.querySelector('.hero-scroll-indicator');
    const video = document.querySelector('.hero-bg-video') as HTMLVideoElement;
    const overlay = document.querySelector('.hero-overlay');

    if (!heroLogo) return;

    // Set initial states
    gsap.set([heroLogo, heroLines, heroCta, scrollIndicator], { 
      opacity: 0, 
      y: 40 
    });
    
    if (video) gsap.set(video, { scale: 1.1, opacity: 0 });
    if (overlay) gsap.set(overlay, { opacity: 0 });

    // Animate in after preloader (if first visit to home) or quickly
    const hasVisited = sessionStorage.getItem('jd-visited');
    const isMainPage = window.location.pathname === '/';
    const delay = (isMainPage && !hasVisited) ? 6 : 0.4;
    
    const tl = gsap.timeline({ delay: delay });
    
    tl.to(video, {
      opacity: 1,
      scale: 1,
      duration: 2,
      ease: "power2.out"
    })
    .to(overlay, {
      opacity: 1,
      duration: 1.5,
      ease: "power2.out"
    }, "-=1.5")
    .to(heroLogo, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: "power3.out"
    }, "-=1")
    .to(heroLines, {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.2,
      ease: "power3.out"
    }, "-=0.6");

    if (heroCta) {
      tl.to(heroCta, {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: "power3.out"
      }, "-=0.6");
    }

    tl.to(scrollIndicator, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: "power3.out"
    }, "-=0.6");

    // Scroll indicator animation
    gsap.to('.scroll-line', {
      scaleY: 0.5,
      yoyo: true,
      repeat: -1,
      duration: 1.5,
      ease: "power1.inOut"
    });

    // Parallax effect on scroll
    gsap.to(video, {
      scrollTrigger: {
        trigger: ".hero",
        start: "top top",
        end: "bottom top",
        scrub: true
      },
      y: 200,
      ease: "none"
    });
  }

  window.addEventListener('DOMContentLoaded', initHero);
</script>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 8rem 2rem 4rem;
    position: relative;
    overflow: hidden;
    background: var(--color-dark);
  }

  .hero-video-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero-bg-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(26, 26, 26, 0.7) 0%,
      rgba(26, 26, 26, 0.5) 50%,
      rgba(240, 105, 45, 0.2) 100%
    );
  }

  .hero-content {
    max-width: 1200px;
    width: 100%;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .hero-logo-container {
    margin-bottom: 3rem;
    display: inline-block;
  }

  .hero-logo {
    height: clamp(100px, 20vw, 200px);
    width: auto;
    filter: brightness(0) invert(1);
    transition: transform 0.3s ease;
  }

  .hero-logo:hover {
    transform: scale(1.05);
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 7rem);
    font-weight: 400;
    line-height: 1.1;
    margin: 0 0 3rem;
    letter-spacing: -0.02em;
  }

  .hero-title .line {
    display: block;
    background: linear-gradient(
      135deg,
      var(--color-light) 0%,
      var(--color-light) 60%,
      var(--color-primary) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary,
  .btn-secondary {
    padding: 1rem 2.5rem;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 0;
    transition: all 0.3s;
    display: inline-block;
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-light);
    border: 2px solid var(--color-primary);
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--color-primary);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-light);
    border: 2px solid var(--color-light);
    backdrop-filter: blur(5px);
  }

  .btn-secondary:hover {
    background: var(--color-light);
    color: var(--color-dark);
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-light);
    opacity: 0.6;
    z-index: 1;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: var(--color-light);
    transform-origin: top;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 6rem 1.5rem 3rem;
    }

    .hero-logo {
      height: 80px;
    }

    .hero-title {
      margin-bottom: 2rem;
    }

    .hero-cta {
      flex-direction: column;
      gap: 1rem;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
      max-width: 300px;
    }
  }
</style>

