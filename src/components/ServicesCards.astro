---
interface Service {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  image: string;
  features: string[];
}

interface Props {
  services: Service[];
  title?: string;
  subtitle?: string;
}

const { 
  services, 
  title = "Nuestros Servicios", 
  subtitle = "Optimización integral" 
} = Astro.props;
---

<section class="services-wrapper">
  <div class="services-header">
    <span class="services-subtitle">{subtitle}</span>
    <h2 class="services-main-title">{title}</h2>
  </div>

  <div class={`services-container ${services.length === 1 ? 'single-service' : ''}`}>
    {services.map((service) => (
      <div class="service-card" id={`service-${service.id}`}>
        <div class="service-image">
          <img src={service.image} alt={service.title} />
          <div class="image-overlay"></div>
        </div>

        <div class="service-content">
          <div class="service-teaser">
            {(() => {
              const parts = service.title.split('(');
              const mainTitle = parts[0].trim();
              const subTitle = parts[1] ? `(${parts[1]}` : '';
              return (
                <h3 class="service-title">
                  {mainTitle} {subTitle && <span class="sub-title">{subTitle}</span>}
                </h3>
              );
            })()}
            <div class="expand-plus">
              <span></span>
              <span></span>
            </div>
          </div>

          <div class="service-details">
            <p class="service-desc">{service.description}</p>
            {service.features && service.features.length > 0 && (
              <ul class="service-features">
                {service.features.map(feature => (
                  <li>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                      <path d="M5 13l4 4L19 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .services-wrapper {
    background: var(--color-dark);
    padding: 10rem 2rem;
    width: 100%;
    overflow: hidden;
  }

  .services-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .services-subtitle {
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 1rem;
    display: block;
  }

  .services-main-title {
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.9;
    color: var(--color-light);
  }

  .services-container {
    display: flex;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    gap: 1.5rem;
    height: 750px;
  }

  .services-container.single-service {
    justify-content: center;
    height: auto;
  }

  .single-service .service-card {
    max-width: 800px;
    flex: none;
    width: 100%;
    height: 750px;
    cursor: default;
  }

  .single-service .service-card .service-image img {
    filter: grayscale(0) brightness(0.4);
    transform: scale(1.05);
  }

  /* Disable hover effects for single service card */
  .single-service .service-card:hover .service-image img {
    transform: scale(1.05);
  }

  .single-service .service-card .service-details {
    max-height: 750px;
    opacity: 1;
    padding-top: 2.5rem;
  }

  .single-service .service-card .service-teaser {
    transform: translateY(-20px) !important;
  }

  .single-service .service-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
  }

  .service-card {
    position: relative;
    flex: 1;
    height: 100%;
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    transition: flex 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    background: #252525;
  }

  .service-card:hover {
    flex: 4;
  }

  .single-service .service-card:hover {
    flex: none;
  }

  /* Image */
  .service-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .service-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) brightness(0.6);
    transition: filter 0.8s ease, transform 0.8s ease;
  }

  .service-card:hover .service-image img {
    filter: grayscale(0) brightness(0.5);
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, transparent 60%);
    z-index: 2;
  }

  /* Content */
  .service-content {
    position: relative;
    z-index: 3;
    height: 100%;
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: var(--color-light);
    pointer-events: none; /* Allows hover on card through content */
  }

  .service-teaser, .service-details {
    pointer-events: auto; /* Allows interaction within content */
  }

  .service-teaser {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    transition: transform 0.6s ease;
  }

  .service-card:hover .service-teaser {
    transform: translateY(-20px);
  }

  .service-number {
    font-family: 'Anton', sans-serif;
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    display: block;
  }

  .service-title {
    font-size: 2.2rem;
    color: var(--color-primary);
    line-height: 1.1;
    margin: 0;
    transition: font-size 0.5s ease;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
  }

  .service-title .sub-title {
    font-size: 1.5rem;
    color: var(--color-light);
    opacity: 0.4;
    font-weight: 300;
    text-transform: none;
    letter-spacing: 0;
    line-height: 1;
  }

  /* Details (Hidden when collapsed) */
  .service-details {
    max-height: 0;
    opacity: 0;
    overflow-y: auto;
    transition: max-height 0.8s ease, opacity 0.5s ease;
    padding-top: 0;
    -webkit-overflow-scrolling: touch; /* Smooth scroll on iOS */
    z-index: 5;
  }

  .expand-plus {
    width: 24px;
    height: 24px;
    position: relative;
    transition: transform 0.4s ease;
    display: block; /* Visible always */
    flex-shrink: 0;
  }

  .expand-plus span {
    position: absolute;
    background: #f0692d; /* Direct brand color */
    background: var(--color-primary, #f0692d);
    transition: all 0.4s ease;
  }

  .expand-plus span:first-child {
    width: 100%;
    height: 2px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  .expand-plus span:last-child {
    width: 2px;
    height: 100%;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
  }

  .service-card:hover .expand-plus {
    transform: rotate(45deg);
  }

  .service-card:hover .expand-plus span:last-child {
    opacity: 0;
  }

  .service-card:hover .service-details {
    max-height: 600px;
    opacity: 1;
    padding-top: 1.5rem;
    overflow-y: auto;
    padding-right: 1rem;
  }

  /* Custom scrollbar for premium feel */
  .service-details::-webkit-scrollbar {
    width: 4px;
  }
  .service-details::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
  }
  .service-details::-webkit-scrollbar-thumb {
    background: var(--color-primary);
    border-radius: 10px;
  }

  .service-desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.8);
    margin-bottom: 2rem;
  }

  .service-features {
    list-style: none;
    padding: 0;
    margin-bottom: 2.5rem;
  }

  .service-features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.8rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .service-features svg {
    width: 18px;
    height: 18px;
    color: var(--color-primary);
  }



  /* Vertical stacking on mobile */
  @media (max-width: 1024px) {
    .services-wrapper {
      padding: 5rem 1.5rem;
    }

    .services-header {
      margin-bottom: 3rem;
    }

    .services-container {
      flex-direction: column;
      height: auto;
      gap: 1.5rem;
    }

    .service-card {
      flex: none;
      width: 100%;
      height: 350px;
    }

    .service-card:hover {
      height: 750px;
    }

    .service-title {
      font-size: 1.6rem;
    }

    .expand-plus {
      width: 20px;
      height: 20px;
    }

    .service-content {
      pointer-events: auto; /* Let content handle taps on mobile */
    }
  }
</style>
