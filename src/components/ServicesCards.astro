---
interface Service {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  image: string;
  features: string[];
}

interface Props {
  services: Service[];
  title?: string;
  subtitle?: string;
}

const { 
  services, 
  title = "Nuestros Servicios", 
  subtitle = "Optimización integral" 
} = Astro.props;
---

<section class="services-wrapper">
  <div class="services-header">
    <span class="services-subtitle">{subtitle}</span>
    <h2 class="services-main-title">{title}</h2>
  </div>

  <div class="services-container">
    {services.map((service) => (
      <div class="service-card" id={`service-${service.id}`}>
        <div class="service-image">
          <img src={service.image} alt={service.title} />
          <div class="image-overlay"></div>
        </div>

        <div class="service-content">
          <div class="service-teaser">
            <span class="service-number">{service.id}</span>
            <h3 class="service-title">{service.title}</h3>
          </div>

          <div class="service-details">
            <p class="service-desc">{service.description}</p>
            <ul class="service-features">
              {service.features.map(feature => (
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path d="M5 13l4 4L19 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .services-wrapper {
    background: var(--color-dark);
    padding: 10rem 2rem;
    width: 100%;
    overflow: hidden;
  }

  .services-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .services-subtitle {
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 1rem;
    display: block;
  }

  .services-main-title {
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.9;
    color: var(--color-light);
  }

  .services-container {
    display: flex;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    gap: 1rem;
    height: 600px;
  }

  .service-card {
    position: relative;
    flex: 1;
    height: 100%;
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    transition: flex 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    background: #252525;
  }

  .service-card:hover {
    flex: 3;
  }

  /* Image */
  .service-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .service-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) brightness(0.6);
    transition: filter 0.8s ease, transform 0.8s ease;
  }

  .service-card:hover .service-image img {
    filter: grayscale(0) brightness(0.5);
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, transparent 60%);
    z-index: 2;
  }

  /* Content */
  .service-content {
    position: relative;
    z-index: 3;
    height: 100%;
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: var(--color-light);
    pointer-events: none;
  }

  .service-teaser {
    transition: transform 0.6s ease;
  }

  .service-card:hover .service-teaser {
    transform: translateY(-20px);
  }

  .service-number {
    font-family: 'Anton', sans-serif;
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    display: block;
  }

  .service-title {
    font-size: 2.5rem;
    line-height: 1;
    margin: 0;
    transition: font-size 0.5s ease;
  }

  /* Details (Hidden when collapsed) */
  .service-details {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.8s ease, opacity 0.5s ease;
    padding-top: 0;
  }

  .service-card:hover .service-details {
    max-height: 500px;
    opacity: 1;
    padding-top: 2rem;
  }

  .service-desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.8);
    margin-bottom: 2rem;
  }

  .service-features {
    list-style: none;
    padding: 0;
    margin-bottom: 2.5rem;
  }

  .service-features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.8rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .service-features svg {
    width: 18px;
    height: 18px;
    color: var(--color-primary);
  }



  /* Vertical stacking on mobile */
  @media (max-width: 1024px) {
    .services-container {
      flex-direction: column;
      height: auto;
      gap: 1.5rem;
    }

    .service-card {
      flex: none;
      width: 100%;
      height: 350px;
    }

    .service-card:hover {
      flex: none;
      height: 550px;
    }

    .service-title {
      font-size: 2rem;
    }
  }
</style>
