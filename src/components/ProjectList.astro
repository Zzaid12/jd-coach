---
const projects = [
  {
    id: 1,
    title: "Neon Genesis",
    category: "Web Design",
    year: "2024",
    video: "https://videos.pexels.com/video-files/3129671/3129671-uhd_2560_1440_30fps.mp4" // Placeholder
  },
  {
    id: 2,
    title: "Cyber Punk",
    category: "Development",
    year: "2023",
    video: "https://videos.pexels.com/video-files/853889/853889-hd_1920_1080_25fps.mp4" // Placeholder
  },
  {
    id: 3,
    title: "Abstract Flow",
    category: "Art Direction",
    year: "2023",
    video: "https://videos.pexels.com/video-files/2759484/2759484-hd_1920_1080_30fps.mp4" // Placeholder
  },
  {
    id: 4,
    title: "Minimalist",
    category: "Branding",
    year: "2022",
    video: "https://videos.pexels.com/video-files/4434242/4434242-hd_1920_1080_24fps.mp4" // Placeholder
  }
];
---

<section class="project-list">
  <div class="list-header">
    <span>PROJECT</span>
    <span>CATEGORY</span>
    <span>YEAR</span>
  </div>
  
  <div class="list-items">
    {projects.map(project => (
      <div class="project-item" data-video={project.video}>
        <div class="project-title">
          <h2>{project.title}</h2>
        </div>
        <div class="project-category">
          <span>{project.category}</span>
        </div>
        <div class="project-year">
          <span>{project.year}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .project-list {
    padding: 10rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .list-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 2rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
  }

  .project-item {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    align-items: center;
    padding: 3rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    transition: opacity 0.3s;
  }

  .project-item:hover {
    opacity: 1;
  }

  .project-list:hover .project-item:not(:hover) {
    opacity: 0.3; /* Focus effect */
  }

  .project-title h2 {
    font-size: 4rem;
    font-weight: 400;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .project-category, .project-year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    color: rgba(255,255,255,0.7);
  }

  @media (max-width: 768px) {
    .project-item {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .list-header {
      display: none;
    }
  }
</style>
