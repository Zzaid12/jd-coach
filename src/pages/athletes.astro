---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ContentShowcase from '../components/ContentShowcase.astro';
import ServicesCards from '../components/ServicesCards.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: "01",
    title: "Planificación Élite",
    subtitle: "Rendimiento puro",
    description: "Programas de entrenamiento personalizados para deportistas que buscan alcanzar su máximo potencial competitivo.",
    image: "/assets/images/training-1.png",
    features: ["Fuerza y potencia específica", "Monitorización de carga", "Preparación pre-temporada"]
  },
  {
    id: "02",
    title: "Readaptación",
    subtitle: "Vuelta segura",
    description: "Recuperación funcional tras lesiones, centrada en equilibrar debilidades y fortalecer la estructura corporal.",
    image: "/assets/images/training-2.png",
    features: ["Control motor avanzado", "Prevención de recaídas", "Entrenamiento de movilidad"]
  },
  {
    id: "03",
    title: "Biomecánica",
    subtitle: "Eficiencia Técnica",
    description: "Análisis detallado de tus movimientos para optimizar la transferencia de fuerza al gesto deportivo real.",
    image: "/assets/images/training-3.png",
    features: ["Optimización técnica", "Análisis de salto", "Prevención de impacto"]
  },
  {
    id: "04",
    title: "JD Online",
    subtitle: "Donde estés",
    description: "Accede a mi metodología a través de nuestra plataforma premium con seguimiento semanal constante.",
    image: "/assets/images/athlete-profile.jpg",
    features: ["App de entrenamiento", "Soporte 24/7", "Feedback nutricional"]
  }
];

const athletesItems = [
  {
    title: "Potencia Atlética",
    subtitle: "Rendimiento Superior",
    description: "Programas diseñados para deportistas que buscan romper sus propios límites a través de la ciencia del movimiento.",
    media: {
      type: 'video' as const,
      src: "/assets/videos/athlete-performance.mp4"
    }
  },
  {
    title: "Entrenamiento de Élite",
    subtitle: "Preparación Real",
    description: "Metodología avanzada aplicada al gesto deportivo. Maximizamos cada vector de fuerza para asegurar tu evolución constante.",
    media: {
      type: 'image' as const,
      src: "/assets/images/training-3.png"
    },
    lightMode: true
  },
  {
    title: "Explosividad Máxima",
    subtitle: "Fuerza y Velocidad",
    description: "Trabajamos en la transferencia de potencia para que seas más rápido y fuerte en el campo de juego.",
    media: {
      type: 'video' as const,
      src: "/assets/videos/athlete-explosive.mp4"
    }
  },
  {
    title: "Jotade Coach",
    subtitle: "Dedicación Plena",
    description: "Un enfoque integral donde el detalle marca la diferencia entre el éxito y la mediocridad.",
    media: {
      type: 'image' as const,
      src: "/assets/images/athlete-profile.jpg"
    },
    lightMode: true
  }
];
---

<Layout title="JD Athletes | JD COACH">
  <main>
    <Hero 
      title="JD Athletes" 
      titleLine2="" 
      videoSrc="/assets/videos/hero-secondary.mp4" 
      showCta={false}
    />
    
    <ContentShowcase items={athletesItems} />
    
    <ServicesCards services={services} title="Entrenamiento Elite" subtitle="Lleva tu deporte al siguiente nivel" />

    <Footer />
  </main>
</Layout>

<style>
</style>
