---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ContentShowcase from '../components/ContentShowcase.astro';
import PlayerGallery from '../components/PlayerGallery.astro';
import Footer from '../components/Footer.astro';

const athletesServices = [
  {
    title: "POST-SEASON PROGRAM",
    subtitle: "Under-23 Performance",
    description: "Programa diseñado para explotar el potencial físico y técnico de jugadores en desarrollo tras finalizar la temporada competiriva.",
    features: [
      "Para jugadores en desarrollo (Under-23)",
      "Planificación basada en la edad madurativa",
      "Cuestionario y valoración inicial detallada",
      "Programa por categoría, edad, sexo y eslabones débiles",
      "Seguimiento diario cómodo por medio de la app HARBIZ",
      "PRECIO: 109€ (OFERTA EN PAREJA: 150€)"
    ],
    media: {
      type: 'video' as const,
      src: "/assets/WEB/JD ATHLETES/Vídeo 2. PostSeason Porgram.mp4"
    }
  },
  {
    title: "PROGRAMA INDIVIDUAL",
    subtitle: "Máximo Potencial",
    description: "Enfoque integral y profundo para exprimir cada vector de fuerza y cada sistema biológico al servicio del gesto deportivo.",
    features: [
      "Para pros o jugadores de alto rendimiento",
      "Enfoque: físico, fisiológico, ocular, pisada, mandíbula, sistema vestibular...",
      "Valoración inicial en sesión individual",
      "Programación individualizada por medio de HARBIZ",
      "Posibilidad de trabajo presencial",
      "Precio: 120€ mes"
    ],
    media: {
      type: 'image' as const,
      src: "/assets/WEB/JD ATHLETES/Foto 3. Programa individual.jpg"
    },
    lightMode: true
  },
  {
    title: "SERVICIOS ASOCIADOS",
    subtitle: "Rendimiento 360º",
    description: "Acceso a una red de especialistas de élite para cubrir todas las necesidades del deportista profesional.",
    features: [
      "Centro de fisioterapia especializada en recuperación",
      "Servicio de Podología y Nutrición/Suplementación",
      "Experto en microbiota y Optometrista (Sist. Visual)",
      "Experto en articulación atemporomandibular",
      "Asesoría fiscal y laboral para deportistas"
    ],
    media: {
      type: 'image' as const,
      src: "/assets/WEB/JD ATHLETES/Foto 4. Servicios asociados.jpg"
    }
  },
  {
    title: "SERVICIO PRESENCIAL",
    subtitle: "Sede Madrid",
    description: "Atención directa y presencial en nuestra sede principal para garantizar la máxima calidad técnica en cada repetición.",
    features: [
      "Sede principal Madrid (Calle Arregui y Aruej)",
      "Plazas muy limitadas",
      "Solo para miembros del programa",
      "Máximo compromiso y seguimiento real"
    ],
    media: {
      type: 'video' as const,
      src: "/assets/WEB/JD ATHLETES/Video 5. Servicio presencial.mp4"
    },
    lightMode: true
  }
];

