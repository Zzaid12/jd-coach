---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ContentShowcase from '../components/ContentShowcase.astro';
import ServicesCards from '../components/ServicesCards.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: "01",
    title: "POST-SEASON PROGRAM",
    subtitle: "Para jugadores en desarrollo (U-23)",
    description: "Programa basado en su edad madurativa para explotar el potencial físico y técnico tras la temporada.",
    image: "/assets/images/training-1.png",
    features: [
      "Cuestionario y valoración inicial", 
      "Programa por categoría, edad, sexo y eslabones débiles", 
      "Seguimiento diario por App HARBIZ", 
      "PRECIO: 109€", 
      "OFERTA EN PAREJA: 150€"
    ]
  },
  {
    id: "02",
    title: "PROGRAMA INDIVIDUAL",
    subtitle: "Para pros o máximo potencial",
    description: "Enfoque integral: físico, fisiológico, ocular, pisada, mandíbula, sis. vestibular… conócete a fondo.",
    image: "/assets/images/training-2.png",
    features: [
      "Valoración inicial en sesión individual",
      "Programación por HARBIZ (App intuitiva)",
      "Posibilidad de trabajo presencial",
      "PRECIO: 120€ / MES"
    ]
  },
  {
    id: "03",
    title: "SERVICIOS ASOCIADOS",
    subtitle: "Red de especialistas",
    description: "Acceso a nuestro centro de fisioterapia especializada en recuperación y alto rendimiento.",
    image: "/assets/images/training-3.png",
    features: [
      "Podología y Nutrición/Suplementación",
      "Experto en microbiota",
      "Optometrista (Especialista sist. visual)",
      "Experto en articulación mandíbular (ATM)",
      "Asesoría fiscal y laboral"
    ]
  },
  {
    id: "04",
    title: "SERVICIO PRESENCIAL",
    subtitle: "Sede Madrid",
    description: "Sede principal en Madrid (Calle Arregui y Aruej). Solo para miembros del programa.",
    image: "/assets/images/athlete-profile.jpg",
    features: [
      "Plazas muy limitadas",
      "Sede Calle Arregui y Aruej",
      "Exclusivo para miembros del programa"
    ]
  }
];

const athletesItems = [
  {
    title: "Potencia Atlética",
    subtitle: "Rendimiento Superior",
    description: "Programas diseñados para deportistas que buscan romper sus propios límites a través de la ciencia del movimiento.",
    media: {
      type: 'video' as const,
      src: "/assets/videos/athlete-performance.mp4"
    }
  },
  {
    title: "Entrenamiento de Élite",
    subtitle: "Preparación Real",
    description: "Metodología avanzada aplicada al gesto deportivo. Maximizamos cada vector de fuerza para asegurar tu evolución constante.",
    media: {
      type: 'image' as const,
      src: "/assets/images/training-3.png"
    },
    lightMode: true
  },
  {
    title: "Explosividad Máxima",
    subtitle: "Fuerza y Velocidad",
    description: "Trabajamos en la transferencia de potencia para que seas más rápido y fuerte en el campo de juego.",
    media: {
      type: 'video' as const,
      src: "/assets/videos/athlete-explosive.mp4"
    }
  },
  {
    title: "Jotade Coach",
    subtitle: "Dedicación Plena",
    description: "Un enfoque integral donde el detalle marca la diferencia entre el éxito y la mediocridad.",
    media: {
      type: 'image' as const,
      src: "/assets/images/athlete-profile.jpg"
    },
    lightMode: true
  }
];
---

<Layout title="JD Athletes | JD COACH">
  <main>
    <Hero 
      title="JD Athletes" 
      titleLine2="" 
      videoSrc="/assets/videos/hero-secondary.mp4" 
      showCta={false}
    />
    
    <ContentShowcase items={athletesItems} />
    
    <ServicesCards services={services} title="Entrenamiento Elite" subtitle="Lleva tu deporte al siguiente nivel" />

    <Footer />
  </main>
</Layout>

<style>
</style>
