---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ContentShowcase from '../components/ContentShowcase.astro';
import Footer from '../components/Footer.astro';

const performersServices = [
  {
    title: "ENTRENAMIENTO ONLINE",
    subtitle: "MÁXIMA IMPLICACIÓN",
    description: "“Programas personalizados con la máxima implicación, porque tú bienestar no admite excusas”",
    features: [
      "Trabaja en base a tus objetivos, necesidades y disponibilidad",
      "Planificación mensual y seguimiento constante (App HARBIZ)",
      "Desde lesiones a control de peso, pasando por opositores",
      "Entrena como un deportista, para cumplir con tus retos del día a día",
      "PRECIOS: 2 ses/sem = 97€ al mes | 3+ ses/sem = 121€ al mes"
    ],
    media: {
      type: 'video' as const,
      src: "/assets/WEB/JD PERFORMERS/Vídeo 2. Entrenamiento Online.mp4"
    }
  }
];
---

<Layout title="JD Performers | JD COACH">
  <main>
    <Hero 
      title="JD Performers" 
      titleLine2="Rendimiento real para personas comprometidas con su salud" 
      videoSrc="/assets/videos/hero-secondary.mp4" 
      showCta={false}
    />
    
    <ContentShowcase items={performersServices} />
    
    <section class="cta-final-section">
      <div class="cta-image-container">
        <img src="/assets/WEB/JD PERFORMERS/Foto 3. Quiero empezar ya!.jpg" alt="Quiero empezar ya" class="cta-bg-image" />
        <div class="cta-overlay"></div>
      </div>
      
      <div class="cta-content">
        <h2 class="cta-title">QUIERO EMPEZAR YA</h2>
        <a href="https://docs.google.com/forms/d/e/1FAIpQLSdYNlrmsiJ9UrIF8Ta5XfXpm-PZgy8gUUGYocrTDzssaPdzkw/viewform" target="_blank" class="cta-button">
          RELLENAR FORMULARIO
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </section>
    
    <Footer />
  </main>
</Layout>

<style>
  .cta-final-section {
    position: relative;
    height: 350px; /* Sección corta como solicitado */
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--color-dark);
  }

  .cta-image-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .cta-bg-image {
    width: 100%;
    height: 120%; /* Un poco más de altura para permitir el parallax/movimiento */
    top: -10%;
    position: absolute;
    object-fit: cover;
    object-position: center 15%; /* Muestra más de la parte superior */
    filter: brightness(0.4);
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cta-final-section:hover .cta-bg-image {
    transform: scale(1.02);
  }

  .cta-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, var(--color-dark) 0%, transparent 50%, var(--color-dark) 100%);
  }

  .cta-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 2rem;
    width: 100%;
  }

  .cta-title {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    color: var(--color-light);
    text-transform: uppercase;
    margin-bottom: 2rem;
    line-height: 0.9;
    letter-spacing: -0.02em;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background-color: var(--color-primary);
    color: #ffffff;
    text-decoration: none;
    padding: 1.25rem 2.5rem;
    border-radius: 100px;
    font-family: 'Anton', sans-serif;
    font-size: 1.25rem;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border: 2px solid var(--color-primary);
  }

  .cta-button:hover {
    background-color: transparent;
    color: var(--color-primary);
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 15px 30px rgba(240, 105, 45, 0.3);
  }

  .cta-button svg {
    width: 24px;
    height: 24px;
    transition: transform 0.3s ease;
  }

  .cta-button:hover svg {
    transform: translateX(5px);
  }

  @media (max-width: 768px) {
    .cta-final-section {
      height: 300px;
    }
    .cta-title {
      font-size: 2.2rem;
    }
  }
</style>
