---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contacto | JD COACH">
  <main class="contact-page">
    <div class="contact-wrapper">
      <h1 class="contact-hero-title">Contáctame</h1>
      
      <div class="contact-grid">
        <div class="contact-box">
          <span class="box-label">Email</span>
          <a href="mailto:jotade.performance@gmail.com" class="box-link">jotade.performance@gmail.com</a>
        </div>
        <div class="contact-box">
          <span class="box-label">Llámame</span>
          <a href="tel:+34628439905" class="box-link">+34 628 43 99 05</a>
        </div>
      </div>

      <div class="contact-actions">
        <a href="https://wa.me/34628439905" target="_blank" class="whatsapp-btn">
          <span class="btn-text">ABRIR WHATSAPP</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="whatsapp-icon"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-13.4 8.38 8.38 0 0 1 3.8.9L21 3z"></path></svg>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";

  function initContactAnimations() {
    const title = document.querySelector('.contact-hero-title');
    const boxes = document.querySelectorAll('.contact-box');
    const whatsappBtn = document.querySelector('.whatsapp-btn');
    
    if (!title || !whatsappBtn) return;

    const tl = gsap.timeline({ delay: 0.2 });
    
    tl.fromTo(title, 
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, ease: "power3.out" }
    )
    .fromTo(boxes, 
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.6, stagger: 0.1, ease: "power3.out" },
      "-=0.4"
    )
    .fromTo(whatsappBtn, 
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.6, ease: "power3.out" },
      "-=0.3"
    );
  }

  window.addEventListener('DOMContentLoaded', initContactAnimations);
</script>

<style>
  .contact-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 2rem 6rem;
    background-color: var(--color-dark);
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .contact-wrapper {
    max-width: 800px;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .contact-hero-title {
    font-family: 'Anton', sans-serif;
    font-size: clamp(3.5rem, 10vw, 7rem);
    text-transform: uppercase;
    line-height: 0.9;
    margin-bottom: 4rem;
    color: var(--color-light);
    letter-spacing: -0.02em;
    opacity: 0; /* Fallback for GSAP */
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .contact-box {
    background-color: #ffffff;
    padding: 3rem 2rem;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    opacity: 0; /* Fallback for GSAP */
  }

  .contact-box:hover {
    transform: translateY(-8px);
  }

  .box-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    color: #888888;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.75rem;
    letter-spacing: 0.1em;
  }

  .box-link {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    color: #1a1a1a;
    font-weight: 800;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-actions {
    width: 100%;
    margin-top: 1rem;
  }

  .whatsapp-btn {
    width: 100%;
    padding: 2rem;
    border-radius: 100px;
    background-color: var(--color-primary, #f0692d);
    color: #ffffff;
    font-family: 'Anton', sans-serif;
    font-size: 1.75rem;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    transition: all 0.3s ease;
    letter-spacing: 0.05em;
    border: 3px solid var(--color-primary, #f0692d);
    opacity: 0; /* Fallback for GSAP */
    box-shadow: 0 10px 30px rgba(240, 105, 45, 0.2);
  }

  .whatsapp-btn:hover {
    background-color: transparent;
    color: var(--color-primary, #f0692d);
    transform: scale(1.02);
    box-shadow: 0 20px 40px rgba(240, 105, 45, 0.3);
  }

  .whatsapp-icon {
    transition: transform 0.3s ease;
  }

  .whatsapp-btn:hover .whatsapp-icon {
    transform: rotate(15deg) scale(1.1);
  }

  @media (max-width: 768px) {
    .contact-page {
      padding-top: 8rem;
    }

    .contact-hero-title {
      margin-bottom: 3rem;
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .contact-box {
      padding: 2rem;
    }

    .whatsapp-btn {
      padding: 1.5rem;
      font-size: 1.4rem;
    }
  }
</style>
